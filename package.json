{
  "name": "v4",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 4000",
    "build": "pnpm shadcn build && next build",
    "start": "next start --port 4000",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "format:write": "prettier --write \"**/*.{ts,tsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,mdx}\" --cache",
    "registry:build": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/build-registry.mts && prettier --log-level silent --write \"registry/**/*.{ts,tsx,json,mdx}\" --cache",
    "registry:capture": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/capture-registry.mts",
    "rss:build": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/build-rss.mts",
    "validate:registries": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/validate-registries.mts",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@faker-js/faker": "^8.2.0",
    "@hookform/resolvers": "^3.10.0",
    "@lexical/code": "^0.35.0",
    "@lexical/file": "^0.35.0",
    "@lexical/hashtag": "^0.35.0",
    "@lexical/link": "^0.35.0",
    "@lexical/list": "^0.35.0",
    "@lexical/markdown": "0.35.0",
    "@lexical/overflow": "^0.35.0",
    "@lexical/react": "^0.35.0",
    "@lexical/rich-text": "^0.35.0",
    "@lexical/selection": "0.35.0",
    "@lexical/table": "^0.35.0",
    "@lexical/text": "^0.35.0",
    "@lexical/utils": "0.35.0",
    "@tabler/icons-react": "^3.31.0",
    "@tailwindcss/postcss": "^4.0.1",
    "@tanstack/react-table": "^8.9.1",
    "@vercel/analytics": "^1.4.1",
    "change-case": "^5.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-autoplay": "8.5.2",
    "embla-carousel-react": "8.5.2",
    "fumadocs-core": "^15.3.1",
    "fumadocs-docgen": "^2.0.0",
    "fumadocs-mdx": "^11.6.3",
    "fumadocs-ui": "^15.3.1",
    "input-otp": "^1.4.2",
    "jotai": "^2.1.0",
    "lexical": "^0.35.0",
    "lodash": "^4.17.21",
    "lucide-react": "0.474.0",
    "motion": "^12.12.1",
    "next": "16.0.10",
    "next-themes": "0.4.6",
    "postcss": "^8.5.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-colorful": "^5.6.1",
    "react-day-picker": "^9.7.0",
    "react-dom": "19.2.3",
    "react-error-boundary": "^5.0.0",
    "react-hook-form": "^7.54.2",
    "react-resizable-panels": "^4",
    "recharts": "2.15.1",
    "rehype-pretty-code": "^0.14.1",
    "rimraf": "^6.0.1",
    "shadcn": "3.2.1",
    "shiki": "^1.10.1",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.0.1",
    "ts-morph": "18.0.0",
    "vaul": "1.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "@tailwindcss/postcss": "^4",
    "@types/katex": "^0.16.7",
    "@types/lodash": "^4.17.7",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.1.4",
    "tw-animate-css": "^1.2.4",
    "typescript": "^5",
    "unist-builder": "3.0.0",
    "unist-util-visit": "^4.1.2"
  },
  "prettier": {
    "endOfLine": "lf",
    "semi": false,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "es5",
    "importOrder": [
      "^(react/(.*)$)|^(react$)",
      "^(next/(.*)$)|^(next$)",
      "<THIRD_PARTY_MODULES>",
      "",
      "^@workspace/(.*)$",
      "",
      "^types$",
      "^@/types/(.*)$",
      "^@/config/(.*)$",
      "^@/lib/(.*)$",
      "^@/hooks/(.*)$",
      "^@/components/ui/(.*)$",
      "^@/components/(.*)$",
      "^@/registry/(.*)$",
      "^@/styles/(.*)$",
      "^@/app/(.*)$",
      "^@/www/(.*)$",
      "",
      "^[./]"
    ],
    "importOrderParserPlugins": [
      "typescript",
      "jsx",
      "decorators-legacy"
    ],
    "plugins": [
      "@ianvs/prettier-plugin-sort-imports",
      "prettier-plugin-tailwindcss"
    ]
  }
}
